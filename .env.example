# Statusy Environment Variables
# Copy this file to .env and adjust values as needed.

# Port exposed on the host (default: 8080)
PORT=8080

# JWT secret for authentication — MUST be changed in production!
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# If running without docker-compose, set this directly:
# STATUSY_AUTH_JWT_SECRET=your-long-random-secret-here

# Initial admin user (created automatically on first run if no admin exists)
# If not set, defaults to admin / admin — CHANGE AFTER FIRST LOGIN!
STATUSY_ADMIN_USERNAME=admin
STATUSY_ADMIN_EMAIL=admin@example.com
STATUSY_ADMIN_PASSWORD=admin
